# ============================================================
#  SILLABO — configurazione ambiente
#  Copia questo file in `.env` nella radice del repo e completa
#  i valori contrassegnati. Il file .env NON va mai committato.
# ============================================================

# --- Supabase (progetto "sillabo", regione eu-central-1) -----
# URL del progetto: gia' corretto, non serve cambiarlo.
SUPABASE_URL=https://fxtpzstsoqygmxehzfxf.supabase.co
VITE_SUPABASE_URL=https://fxtpzstsoqygmxehzfxf.supabase.co

# Chiave pubblica (anon / publishable):
# dashboard Supabase -> progetto "sillabo" -> Settings -> API Keys
# https://supabase.com/dashboard/project/fxtpzstsoqygmxehzfxf/settings/api-keys
SUPABASE_ANON_KEY=INCOLLA_QUI_LA_CHIAVE_ANON
VITE_SUPABASE_ANON_KEY=INCOLLA_QUI_LA_CHIAVE_ANON

# Connessione diretta al database Postgres (usata dall'API e da drizzle-kit).
# dashboard Supabase -> progetto "sillabo" -> pulsante "Connect" in alto
# -> scheda "Session pooler" -> copia la stringa e sostituisci [YOUR-PASSWORD]
# (se non ricordi la password del database: Settings -> Database -> Reset password)
DATABASE_URL=postgresql://postgres.fxtpzstsoqygmxehzfxf:[LA-TUA-PASSWORD]@aws-1-eu-central-1.pooler.supabase.com:5432/postgres

# --- Anthropic (funzioni AI: domande, interrogazioni, correzioni) ---
# Crea la chiave su https://console.anthropic.com -> API Keys
ANTHROPIC_API_KEY=INCOLLA_QUI_LA_CHIAVE_ANTHROPIC
# Modello usato per le funzioni AI (opzionale, questo e' il default)
# ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Server API (opzionale) ---
# PORT=3001
